# Copy to .env (gitignored). Expo loads EXPO_PUBLIC_* automatically.
#
# Local LAN (same Wi‑Fi as device) — do not use localhost on a physical phone:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:3000
#
# Preview / staging — HTTPS hostname (set the same in EAS secrets for preview builds):
# EXPO_PUBLIC_API_BASE_URL=https://api-staging.example.com

# When the server has SLOTSYNC_API_KEY set, the app must send the same value (embedded in the binary — fine for private beta only):
# EXPO_PUBLIC_SLOTSYNC_API_KEY=your-long-random-secret
# (Alias: EXPO_PUBLIC_API_KEY)

# Optional: default ESP32 shelf origin if you do not use Settings → Shelf connection
# EXPO_PUBLIC_SHELF_BASE_URL=http://192.168.1.50

# Optional: verbose identification logs in dev
# EXPO_PUBLIC_DEBUG_IDENTIFICATION=true

# Optional: only used in release builds (__DEV__ skips Sentry init)
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Usually set by EAS / app.config.js, not needed locally:
# EXPO_PUBLIC_APP_ENV=development
