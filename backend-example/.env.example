# SlotSync Backend Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env or credentials.json to version control

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# Google Vision API (Optional - for OCR and image analysis)
# ============================================================================
# Path to Google Cloud service account JSON file
# If not set, server will auto-discover from:
#   - backend-example/credentials.json
#   - backend-example/credentials/credentials.json
#   - ../credentials.json (repo root)
# If not found, server runs in degraded mode (Discogs-only)
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================================
# Discogs API (Required for record identification)
# ============================================================================
# Personal Access Token (recommended) - Get from https://www.discogs.com/settings/developers
DISCOGS_PERSONAL_ACCESS_TOKEN=

# OR use API Key + Secret (legacy)
# DISCOGS_API_KEY=
# DISCOGS_API_SECRET=

# User agent for Discogs API requests
DISCOGS_USER_AGENT=SlotSync/1.0 (contact@slotsync.app)

# ============================================================================
# Optional: OpenAI API (for GPT-4 Vision if enabled)
# ============================================================================
# OPENAI_API_KEY=

# ============================================================================
# Optional: Feature Flags
# ============================================================================
# ENABLE_GOOGLE_VISION=true
# ENABLE_GPT4_VISION=false
# USE_GPT_OCR_PARSING=false

# ============================================================================
# Optional: Timeouts (milliseconds)
# ============================================================================
# VISION_TIMEOUT_MS=20000
# DISCOGS_SEARCH_TIMEOUT_MS=12000
# DISCOGS_FETCH_TIMEOUT_MS=12000
# EMBEDDING_TIMEOUT_MS=30000
# REQUEST_TIMEOUT_MS=85000
# REQUEST_DEADLINE_MS=80000

# ============================================================================
# Optional: Scoring Thresholds
# ============================================================================
# AUTO_ACCEPT_THRESHOLD=0.8
# SUGGESTIONS_THRESHOLD=0.5
# CONFIDENCE_THRESHOLD=0.5

# ============================================================================
# Optional: CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins (leave empty for dev defaults)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ============================================================================
# Optional: Logging
# ============================================================================
# LOG_LEVEL=info
# DEBUG_IDENTIFY=false
# DEBUG_EMBEDDINGS=false
# DEBUG_SCORING=false

# ============================================================================
# Optional: Self-Tests (run at startup)
# ============================================================================
# DISCOGS_SELF_TEST=false
